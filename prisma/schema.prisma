// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model employees {
  id             Int           @id @default(autoincrement())
  username       String
  password       String
  name           String
  surname        String
  email          String?
  img            String?
  status         String        @default("ON")
  position_id    Int
  login_fail     Int
  created_by     String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  birthday       DateTime
  id_google      String?       @unique
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
}

model categorystock {
  id              Int      @id @default(autoincrement())
  categoryName    String
  requiresKitchen Boolean  @default(true)
  printerName     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categoryCode      String? // เก็บ 'A', 'B', 'C'
  menuRunningNumber Int     @default(0) // เก็บตัวเลขล่าสุดที่ถูกรันไปแล้ว

  createdById Int
  creator     employeepin @relation(fields: [createdById], references: [id])

  stocks         stock[]
  menu           menu[]
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])

  @@map("categorystock")
}

model supplier {
  id           Int      @id @default(autoincrement())
  supplierName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById Int
  creator     employeepin @relation(fields: [createdById], references: [id])

  stocks         stock[]
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
}

model stock {
  id          Int      @id @default(autoincrement())
  productName String
  quantity    Int
  price       Float
  max         Float    @default(0)
  min         Float    @default(0)
  unit        String
  description String?
  img         String?
  status      String   @default("ON_STOCK")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById    Int
  creator        employeepin   @relation(fields: [createdById], references: [id])
  categoryId     Int
  category       categorystock @relation(fields: [categoryId], references: [id])
  supplierId     Int
  supplier       supplier      @relation(fields: [supplierId], references: [id])
  unitPriceId    Int           @default(1)
  unitPrice      unitprice     @relation(fields: [unitPriceId], references: [id])
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])

  formularstock formularstock[]
}

model menu {
  id            Int      @id @default(autoincrement())
  menuCode      String? // เก็บ 'A1', 'B1'
  menuName      String
  price_sale    Float
  price_cost    Float
  package_hours Int?
  price_package Float?
  unit          String
  img           String?
  description   String?
  status        String   @default("OFF_SALE") //@default("ON_SALE") for SALE menu
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdById    Int
  creator        employeepin   @relation("MenuCreator", fields: [createdById], references: [id])
  categoryMenuId Int
  category       categorystock @relation(fields: [categoryMenuId], references: [id])
  unitPriceId    Int           @default(1)
  unitPrice      unitprice     @relation(fields: [unitPriceId], references: [id])
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
  mcEmployeeId   Int?
  mcEmployee     employeepin?  @relation("MenuMC", fields: [mcEmployeeId], references: [id])

  formularstock formularstock[]
  order         order[]
  carts         cart[]
  modifiers     menumodifier[]
  orderitems    orderitem[]
}

model formularstock {
  id         Int      @id @default(autoincrement())
  pcs_update Int
  status     String   @default("RUN_FORMULAR")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  menuId         Int
  menu           menu          @relation(fields: [menuId], references: [id])
  stockId        Int
  stock          stock         @relation(fields: [stockId], references: [id])
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
}

model table {
  id             Int      @id @default(autoincrement())
  status         String
  tableName      String
  tableBookingBy String?
  cashType       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posX            Float   @default(0) // X = แนวนอน
  posY            Float   @default(0) // Y = แนวตั้ง
  width           Float   @default(120) // width = กว้าง
  height          Float   @default(120) // height = สูง
  rotation        Float   @default(0) // มุมหมุนโต๊ะ
  floorPlanLocked Boolean @default(false) // ล็อคโต๊ะ
  shape           String  @default("circle") // รูปทรงโต๊ะ
  seatCount       Int     @default(4) // จำนวนที่นั่ง

  closeById Int
  creator   employeepin @relation(fields: [closeById], references: [id])

  order          order[]
  carts          cart[]
  paymentorders  paymentorder[]
  organizationId Int?
  organization   organization?  @relation(fields: [organizationId], references: [id])
}

model order {
  id             Int      @id @default(autoincrement())
  quantity       Int
  price_sum      Float
  price_pre_unit Float
  orderDetail    String?
  note           String?
  status         String
  employeeId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menuId             Int
  menu               menu                @relation(fields: [menuId], references: [id])
  tableId            Int
  table              table               @relation(fields: [tableId], references: [id])
  organizationId     Int?
  organization       organization?       @relation(fields: [organizationId], references: [id])
  order_running_code String?
  runningRef         orderrunning?       @relation(fields: [order_running_code], references: [runningCode])
  orderitems         orderitem[]
  membertransactions membertransaction[]
}

model unitprice {
  id        Int      @id @default(autoincrement())
  value     String
  label     String
  flag      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menus          menu[]
  stocks         stock[]
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
}

model cart {
  id             Int      @id @default(autoincrement())
  quantity       Int
  price_sum      Float
  price_pre_unit Float
  status         String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menuId         Int
  menu           menu           @relation(fields: [menuId], references: [id])
  tableId        Int
  table          table          @relation(fields: [tableId], references: [id])
  organizationId Int?
  organization   organization?  @relation(fields: [organizationId], references: [id])
  modifiers      cartmodifier[]
}

model cartmodifier {
  id Int @id @default(autoincrement())

  cartId Int
  cart   cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  modifierItemId Int
  modifierItem   modifieritem @relation(fields: [modifierItemId], references: [id])

  name  String
  price Float
}

model orderrunning {
  id          Int      @id @default(autoincrement())
  runningCode String   @unique
  createdAt   DateTime @default(now())

  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])

  order        order[]
  paymentorder paymentorder[]
}

model paymentorder {
  id            Int      @id @default(autoincrement())
  cashReceived  Float
  change        Float
  discount      Float    @default(0)
  totalAmount   Float
  paymentMethod String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  createdById         Int
  creator             employeepin           @relation(fields: [createdById], references: [id])
  organizationId      Int?
  organization        organization?         @relation(fields: [organizationId], references: [id])
  tableId             Int?
  table               table?                @relation(fields: [tableId], references: [id])
  order_running_code  String
  runningRef          orderrunning?         @relation(fields: [order_running_code], references: [runningCode])
  shiftId             Int?
  shift               shift?                @relation(fields: [shiftId], references: [id])
  accountTransactions account_transaction[]
}

model organization {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String?
  ownerId   Int
  createdAt DateTime @default(now())

  menus               menu[]
  orders              order[]
  employees           employees[]
  categories          categorystock[]
  tables              table[]
  unitprices          unitprice[]
  carts               cart[]
  stocks              stock[]
  suppliers           supplier[]
  formularstocks      formularstock[]
  order_runnings      orderrunning[]
  paymentorders       paymentorder[]
  printers            printer[]
  stations            station[]
  modifiergroups      modifiergroup[]
  modifieritems       modifieritem[]
  menumodifiers       menumodifier[]
  orderitems          orderitem[]
  ordermodifiers      ordermodifier[]
  posiotions          posiotion[]
  employeepins        employeepin[]
  permissions         permission[]
  displayBackdrops    display_backdrop[]
  shifts              shift[]
  accounts            account[]
  accountCategories   account_category[]
  accountTransactions account_transaction[]
}

model printer {
  id             Int      @id @default(autoincrement())
  printerName    String?
  urlCertificate String?
  urlSignature   String?
  stationUse     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
  createdById    Int
  creator        employeepin   @relation(fields: [createdById], references: [id])
}

model station {
  id          Int      @id @default(autoincrement())
  stationName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
  createdById    Int
  creator        employeepin   @relation(fields: [createdById], references: [id])
}

model modifiergroup {
  id             Int           @id @default(autoincrement())
  name           String
  status         String?
  minSelect      Int           @default(0)
  maxSelect      Int           @default(1)
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])

  items modifieritem[]
  menus menumodifier[]
}

model modifieritem {
  id    Int    @id @default(autoincrement())
  name  String
  price Float  @default(0)

  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
  groupId        Int
  group          modifiergroup @relation(fields: [groupId], references: [id])

  orderModifiers ordermodifier[]
  modifiers      cartmodifier[]
}

model menumodifier {
  id     Int  @id @default(autoincrement())
  menuId Int
  menu   menu @relation(fields: [menuId], references: [id])

  modifierGroupId Int
  modifierGroup   modifiergroup @relation(fields: [modifierGroupId], references: [id])
  organizationId  Int?
  organization    organization? @relation(fields: [organizationId], references: [id])
}

model orderitem {
  id             Int           @id @default(autoincrement())
  orderId        Int
  order          order         @relation(fields: [orderId], references: [id])
  menuId         Int
  menu           menu          @relation(fields: [menuId], references: [id])
  quantity       Int
  price          Float
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])

  selectedModifiers ordermodifier[]
}

model ordermodifier {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  orderItem   orderitem @relation(fields: [orderItemId], references: [id])

  modifierItemId Int
  modifierItem   modifieritem  @relation(fields: [modifierItemId], references: [id])
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])
  price          Float
}

model posiotion {
  id            Int      @id @default(autoincrement())
  position_name String
  status        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  createdById    Int
  creator        employeepin   @relation(fields: [createdById], references: [id])
  organizationId Int?
  organization   organization? @relation(fields: [organizationId], references: [id])

  permissions position_permission[]
}

// =====================================
// Permission = สิทธิ์ (เช่น PROJECT_VIEW, TASK_EDIT)
// - แยกตามบริษัท
// =====================================

model permission {
  id Int @id @default(autoincrement())

  permissionKey  String // รหัสสิทธิ์ เช่น "PROJECT_VIEW"
  permissionName String // ชื่อแสดงผล เช่น "ดูโปรเจค"
  permissionDesc String? // รายละเอียดเพิ่มเติม
  status         String  @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // ---------- relations ----------
  organizationId Int // FK -> organization.id
  organization   organization          @relation(fields: [organizationId], references: [id])
  positions      position_permission[] // ตำแหน่งไหนมีสิทธิ์นี้
}

// =====================================
// PositionPermission = ตารางกลาง (ตำแหน่ง ↔ สิทธิ์)
// - บอกว่า "ตำแหน่งนี้" มี/ไม่มี "สิทธิ์นี้"
// =====================================
model position_permission {
  id      Int     @id @default(autoincrement())
  allowed Boolean @default(false) // เปิด/ปิดสิทธิ์ (เผื่อทำ override)

  positionId Int // FK -> position.id
  position   posiotion @relation(fields: [positionId], references: [id])

  permissionId Int // FK -> permission.id
  permission   permission @relation(fields: [permissionId], references: [id])

  @@unique([positionId, permissionId])
}

// ------------------------------------------------------
// ระบบสมาชิก (Member System)
// ------------------------------------------------------

model member {
  id             Int     @id @default(autoincrement())
  organizationId Int // ผูกกับสาขาหรือร้านค้า (รองรับ Multi-branch)
  phone          String // เบอร์โทรศัพท์ (ใช้ค้นหา/ล็อกอิน)
  firstName      String // ชื่อ
  lastName       String? // นามสกุล (มีหรือไม่มีก็ได้)

  // ยอดคงเหลือต่างๆ
  points        Int   @default(0) // แต้มสะสม
  creditBalance Float @default(0.0) // เครดิตร้านค้า (เงินที่เติมไว้)

  // สถานะและระดับ
  tierId Int? // ระดับสมาชิก (เช่น Bronze, Silver, Gold)
  status String @default("ACTIVE") // ACTIVE, INACTIVE, BANNED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ความสัมพันธ์ (Relations)
  tier         membertier?         @relation(fields: [tierId], references: [id])
  transactions membertransaction[] // ประวัติการได้/ใช้แต้มและเครดิต
  // orders      Order[]             // (ออปชัน) ถ้าคุณอยากผูกบิลเข้ากับสมาชิก ให้ไปเพิ่ม memberId ใน model Order ด้วย

  // ป้องกันเบอร์โทรซ้ำในร้านเดียวกัน
  @@unique([phone, organizationId])
}

model membertier {
  id              Int    @id @default(autoincrement())
  organizationId  Int
  name            String // ชื่อระดับ (เช่น "Gold Member")
  minSpending     Float  @default(0) // ยอดใช้จ่ายขั้นต่ำเพื่อเลื่อนระดับ
  pointMultiplier Float  @default(1.0) // ตัวคูณแต้ม (เช่น จ่าย 100 ได้ 1 แต้ม ถ้า x2 ก็ได้ 2 แต้ม)
  discountPercent Float  @default(0.0) // ส่วนลดพื้นฐานของระดับนี้ (%)

  members member[]
}

// ตารางบันทึกประวัติ (Audit Log) สำคัญมากสำหรับระบบเงินๆ ทองๆ
model membertransaction {
  id             Int             @id @default(autoincrement())
  organizationId Int
  type           transactiontype // ประเภท: EARN, REDEEM, TOPUP, SPEND
  walletType     wallettype // กระเป๋าที่ได้รับผลกระทบ: POINT, CREDIT
  amount         Float // จำนวน (ถ้าติดลบคือใช้ไป, ถ้าบวกคือได้รับ)
  balanceAfter   Float // ยอดคงเหลือหลังทำรายการ (ช่วยตรวจสอบความถูกต้องเวลาข้อมูลพัง)
  note           String? // หมายเหตุ (เช่น "แลกแต้มเป็นส่วนลด", "เติมเงิน") 
  createdAt      DateTime        @default(now())

  memberId Int
  member   member @relation(fields: [memberId], references: [id])

  orderId Int? // ผูกกับบิลไหน (ถ้ามี)
  order   order? @relation(fields: [orderId], references: [id])

  createdById Int? // พนักงานคนที่ทำรายการ
  employee    employeepin? @relation(fields: [createdById], references: [id])
}

enum transactiontype {
  EARN // ได้รับ (เช่น ซื้อของได้แต้ม)
  REDEEM // แลกใช้ (เช่น เอาแต้มไปแลกส่วนลด)
  TOPUP // เติมเงิน (เช่น เติมเครดิตร้าน)
  SPEND // จ่ายเงิน (เช่น ใช้เครดิตร้านจ่ายค่าอาหาร)
  REFUND // คืนเงิน/คืนแต้ม
}

enum wallettype {
  POINT // แต้มสะสม
  CREDIT // เครดิตร้านค้า (เงินสด)
}

model employeepin {
  id          Int       @id @default(autoincrement())
  pin         String
  name        String
  surname     String
  email       String?
  img         String?
  tel         Int?
  status      String    @default("ON")
  position_id Int
  login_fail  Int
  created_by  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  birthday    DateTime?

  organizationId      Int?
  organization        organization?         @relation(fields: [organizationId], references: [id])
  openedShifts        shift[]               @relation("ShiftOpenedBy")
  closedShifts        shift[]               @relation("ShiftClosedBy")
  categorystocks      categorystock[]
  suppliers           supplier[]
  stocks              stock[]
  menus               menu[]                @relation("MenuCreator")
  tables              table[]
  paymentorders       paymentorder[]
  printers            printer[]
  stations            station[]
  posiotions          posiotion[]
  membertransactions  membertransaction[]
  mcMenus             menu[]                @relation("MenuMC")
  displayBackdrops    display_backdrop[]
  accountTransactions account_transaction[]
}

model display_backdrop {
  id             Int           @id @default(autoincrement())
  organizationId Int // เผื่อมีหลายสาขา
  organization   organization? @relation(fields: [organizationId], references: [id])
  createdById    Int? // พนักงานคนที่ทำรายการ
  employee       employeepin?  @relation(fields: [createdById], references: [id])

  imageUrl String
  title    String?
  igName   String? // เพิ่ม: สำหรับเก็บชื่อ IG ของลูกค้า
  message  String? // สำหรับข้อความที่ลูกค้าพิมพ์
  isActive Boolean @default(true)
  sequence Int     @default(0)
  duration Int     @default(10)

  isTemporary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum shiftstatus {
  OPEN
  CLOSED
}

model shift {
  id             Int         @id @default(autoincrement())
  organizationId Int
  status         shiftstatus @default(OPEN)

  startingCash Float  @default(0)
  expectedCash Float?
  endingCash   Float?

  amountQr   Float? @default(0)
  expectedQr Float? @default(0)
  endingQr   Float?

  note String?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  openedById Int
  openedBy   employeepin @relation("ShiftOpenedBy", fields: [openedById], references: [id])

  closedById    Int?
  closedBy      employeepin?   @relation("ShiftClosedBy", fields: [closedById], references: [id])
  organization  organization?  @relation(fields: [organizationId], references: [id])
  paymentorders paymentorder[]

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  accountTransactions account_transaction[]

  @@map("shift")
}

enum account_tx_type {
  SALES // รายรับอัตโนมัติจาก POS (ผูกบิล)
  INCOME // รายรับอื่นๆ (กรอกมือ)
  EXPENSE // รายจ่าย (กรอกมือ)
  TRANSFER_OUT // โอนเงินออกไปยังบัญชีอื่น
  TRANSFER_IN // รับเงินโอนมาจากบัญชีอื่น
  ADJUSTMENT_UP // ปรับยอดเงินเพิ่มขึ้น (กรอกมือ/แอดมิน)
  ADJUSTMENT_DOWN // ปรับยอดเงินลดลง (กรอกมือ/แอดมิน)
  OVERRIDE_BALANCE // แก้ไขเลขยอดเงินในบัญชีตรงๆ (ระบบบันทึกส่วนต่างให้)
  AR_PAYMENT // รับชำระหนี้ (ลูกค้าจ่ายยอดที่เซ็นติดไว้)
}

model account {
  id             Int      @id @default(autoincrement())
  organizationId Int?
  accountName    String // ชื่อบัญชี เช่น "เงินสดในลิ้นชัก", "ธนาคารกสิกรไทย"
  balance        Float    @default(0.00) // ยอดเงินคงเหลือปัจจุบัน
  status         String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization organization?         @relation(fields: [organizationId], references: [id])
  transactions account_transaction[]
}

model account_category {
  id             Int      @id @default(autoincrement())
  organizationId Int?
  name           String // ชื่อหมวดหมู่ เช่น "ค่าวัตถุดิบ", "รายได้เบ็ดเตล็ด"
  type           String // "INCOME" หรือ "EXPENSE" (เอาไว้กรองตอนให้ User เลือกหมวด)
  note           String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization organization?         @relation(fields: [organizationId], references: [id])
  transactions account_transaction[]
}

model account_transaction {
  id             Int  @id @default(autoincrement())
  organizationId Int?
  accountId      Int
  categoryId     Int?

  type           account_tx_type
  amount         Float // จำนวนเงินในรายการนั้นๆ (เก็บเป็นบวกเสมอ)
  accountBalance Float // ยอดเงินคงเหลือในบัญชี ณ ตอนที่ทำรายการ (Running Balance)

  docNumber String? // เลขที่เอกสาร (ถ้ามี)
  title     String // หัวข้อรายการ/รายละเอียด
  note      String? // หมายเหตุเพิ่มเติม
  docFile   String? // URL ไฟล์แนบ หรือรูปใบเสร็จ

  paymentOrderId Int? // ผูกกับบิลหน้าร้าน (สำหรับ type: SALES)
  shiftId        Int? // ผูกกับกะการทำงาน
  createdById    Int // พนักงานผู้ทำรายการ

  transferPairId Int? // กรณีโอนเงิน: ผูก ID ของรายการโอนฝั่งตรงข้าม

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization organization?     @relation(fields: [organizationId], references: [id])
  account      account           @relation(fields: [accountId], references: [id])
  category     account_category? @relation(fields: [categoryId], references: [id])
  paymentorder paymentorder?     @relation(fields: [paymentOrderId], references: [id])
  shift        shift?            @relation(fields: [shiftId], references: [id])
  creator      employeepin       @relation(fields: [createdById], references: [id])
}
